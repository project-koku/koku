{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>konflux-ci/mintmaker//config/renovate/renovate.json"
    ],
    "updateNotScheduled": false,
    "lockFileMaintenance": {
        "enabled": true
    },
    "packageRules": [
        {
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "ci-dependencies",
            "groupSlug": "ci-dependencies",
            "addLabels": [
                "ok-to-skip-smokes"
            ]
        },
        {
            "matchManagers": [
                "pipenv"
            ],
            "matchUpdateTypes": [
                "lockFileMaintenance"
            ],
            "addLabels": [
                "smoke-tests"
            ]
        },
        {
            "matchManagers": [
                "pipenv"
            ],
            "matchUpdateTypes": [
                "major",
                "minor",
                "patch",
                "pin"
            ],
            "enabled": false
        }
    ],
    "schedule": [
        "on Tuesday after 3am and before 10am"
    ],
    "ignorePaths": [
        "dev/containers/**",
        ".pre-commit-config.yaml"
    ]
}
