digraph koku_iam_erd {
    rankdir=TB;
    node [shape=plaintext, fontname="Arial"];
    edge [fontname="Arial"];

    // Title
    label="Koku IAM Database Schema (COST-7342)\nPublic Schema Tables";
    labelloc=t;
    fontsize=16;
    fontname="Arial Bold";

    // api_customer table
    customer [label=<
        <table border="1" cellborder="1" cellspacing="0" cellpadding="6">
            <tr><td bgcolor="lightblue" colspan="2"><b>api_customer</b></td></tr>
            <tr><td align="left">PK</td><td align="left">id: integer</td></tr>
            <tr><td align="left">UQ</td><td bgcolor="lightyellow" align="left"><b>org_id: varchar(36)</b></td></tr>
            <tr><td align="left">UQ</td><td align="left">account_id: varchar(150)</td></tr>
            <tr><td align="left">UQ</td><td bgcolor="lightgreen" align="left"><b>schema_name: text</b></td></tr>
            <tr><td align="left"></td><td align="left">uuid: uuid</td></tr>
            <tr><td align="left"></td><td align="left">date_created: timestamp</td></tr>
            <tr><td align="left"></td><td align="left">date_updated: timestamp</td></tr>
        </table>
    >];

    // api_user table
    user [label=<
        <table border="1" cellborder="1" cellspacing="0" cellpadding="6">
            <tr><td bgcolor="lightblue" colspan="2"><b>api_user</b></td></tr>
            <tr><td align="left">PK</td><td align="left">id: integer</td></tr>
            <tr><td align="left">UQ</td><td bgcolor="pink" align="left"><b>username: varchar(150)</b></td></tr>
            <tr><td align="left"></td><td align="left">uuid: uuid</td></tr>
            <tr><td align="left"></td><td align="left">email: varchar(254)</td></tr>
            <tr><td align="left"></td><td align="left">date_created: timestamp</td></tr>
            <tr><td align="left"></td><td align="left">is_active: boolean</td></tr>
            <tr><td align="left">FK</td><td bgcolor="lightblue" align="left"><b>customer_id → api_customer.id</b></td></tr>
        </table>
    >];

    // api_tenant table
    tenant [label=<
        <table border="1" cellborder="1" cellspacing="0" cellpadding="6">
            <tr><td bgcolor="lightblue" colspan="2"><b>api_tenant</b></td></tr>
            <tr><td align="left">PK</td><td align="left">id: integer</td></tr>
            <tr><td align="left">UQ</td><td bgcolor="lightgreen" align="left"><b>schema_name: varchar(63)</b></td></tr>
        </table>
    >];

    // PostgreSQL schema (not a table, but a database object)
    pg_schema [label=<
        <table border="1" cellborder="1" cellspacing="0" cellpadding="6">
            <tr><td bgcolor="orange" colspan="2"><b>PostgreSQL Schema</b></td></tr>
            <tr><td align="left" colspan="2">org&lt;org_id&gt;</td></tr>
            <tr><td align="left" colspan="2">(e.g., org12345678_test)</td></tr>
            <tr><td align="left" colspan="2"><br/>Contains:</td></tr>
            <tr><td align="left" colspan="2">• reporting_* tables</td></tr>
            <tr><td align="left" colspan="2">• cost_models_* tables</td></tr>
        </table>
    >];

    // x-rh-identity header
    header [label=<
        <table border="1" cellborder="1" cellspacing="0" cellpadding="6">
            <tr><td bgcolor="lavender" colspan="2"><b>x-rh-identity Header</b></td></tr>
            <tr><td align="left">org_id:</td><td align="left">20013903_test</td></tr>
            <tr><td align="left">account_number:</td><td align="left">12679052</td></tr>
            <tr><td align="left">username:</td><td align="left">rapidast-security</td></tr>
        </table>
    >];

    // Problem annotation
    problem [label=<
        <table border="2" cellborder="0" cellspacing="0" cellpadding="8">
            <tr><td bgcolor="pink" align="center"><b>⚠️ PROBLEM</b></td></tr>
            <tr><td align="left">username is UNIQUE<br/>across ALL customers!</td></tr>
            <tr><td align="left"><br/><b>After Stage refresh:</b><br/>
            • New org_id arrives<br/>
            • New Customer created ✓<br/>
            • But old User blocks<br/>
              new User creation ✗
            </td></tr>
        </table>
    >];

    // Relationships
    user -> customer [label="  FK: customer_id  ", fontsize=11, color=blue, penwidth=2];
    customer -> tenant [label="  schema_name\n  (lookup)  ", style=dashed, color=darkgreen, fontsize=10, penwidth=2];
    tenant -> pg_schema [label="  defines  ", style=dashed, color=orange, fontsize=10, penwidth=1.5];
    header -> customer [label="  org_id lookup  ", style=dotted, color=blue, fontsize=10, penwidth=2];
    header -> user [label="  username lookup  ", style=dotted, color=red, fontsize=10, penwidth=2];
    user -> problem [style=dotted, color=red, penwidth=1];

    // Layout hints
    {rank=same; header; problem;}
    {rank=same; customer; tenant;}
}
